{
  "name": "JARVIS Phone Agent Suite",
  "tagline": "A voice-first AI that can actually use your phone for you.",
  "modules": [
    {
      "id": "jarvis-mobile",
      "path": "apps/jarvis-mobile",
      "stack": "Flutter",
      "role": "Primary mobile shell, voice assistant UI, camera-backed HUD, wake-word experience",
      "featureFlags": [
        "voice-assistant",
        "wake-word",
        "camera-context",
        "hud-interface",
        "task-management",
        "waveform-visualization",
        "vitals-panel"
      ]
    },
    {
      "id": "jarvis-control-web",
      "path": "apps/jarvis-control-web",
      "stack": "Next.js + Mastra",
      "role": "Android screen understanding, planning, ADB execution, verification loop",
      "featureFlags": [
        "adb-control",
        "screen-analysis",
        "planner-agent",
        "executor-agent",
        "verification-loop",
        "device-monitoring"
      ]
    },
    {
      "id": "jarvis-agent-server",
      "path": "apps/jarvis-agent-server",
      "stack": "TypeScript + Express",
      "role": "Rooted Android agent API, notification triage, scheduler, lock management",
      "featureFlags": [
        "http-api",
        "device-lock",
        "notification-watcher",
        "notification-filter",
        "scheduler",
        "termux-integration"
      ]
    },
    {
      "id": "jarvis-motion-web",
      "path": "apps/jarvis-motion-web",
      "stack": "Next.js",
      "role": "Optional motion coaching side feature using camera, pose scoring, and report generation",
      "featureFlags": [
        "pose-tracking",
        "gesture-control",
        "coach-feedback",
        "report-cards",
        "youtube-ingest",
        "zoom-mode",
        "video-generation"
      ]
    }
  ]
}
